# OpenDota API key (optional — increases rate limits from ~30/min to 3000/min)
# Get yours at: https://www.opendota.com/api-keys
OPENDOTA_API_KEY=your_api_key_here

# Proxy for Polymarket API requests (optional)
# Needed if gamma-api.polymarket.com is geo-blocked in your region but Dota 2
# must stay on the direct connection (e.g. Cloudflare WARP conflict).
#
# Cloudflare WARP exposes a local SOCKS5 proxy — enable it in:
#   WARP Settings → Preferences → Advanced → Enable local proxy (default port 40000)
# Then set WARP to "Disconnected" so Dota 2 works, and route only Polymarket
# API traffic through the local proxy:
#
# POLYMARKET_PROXY=socks5h://127.0.0.1:40000
#
# The "socks5h" scheme (note the h) ensures DNS is resolved by the proxy too.
# Requires: pip install PySocks  (already in requirements.txt)
